{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CoreCraft Operator Permissions",
  "description": "Definiert alle granularen Berechtigungen des Operator-Systems im Genesis Operational Layer.",
  "type": "object",

  "properties": {
    "permissions": {
      "type": "array",
      "description": "Liste aller gültigen Operator-Berechtigungen.",
      "items": {
        "type": "string",
        "enum": [
          "canTriggerRituals",
          "canWriteEcho",
          "canAuthorizePayouts",
          "canModifyOperators",
          "canModifyGenesis",
          "canModifySkeletton"
        ]
      }
    }
  },

  "required": ["permissions"]
}
