{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CoreCraft Operator Roles",
  "description": "Definiert alle funktionalen Rollen des Operator-Systems im Genesis Operational Layer.",
  "type": "object",

  "properties": {
    "roles": {
      "type": "array",
      "description": "Liste aller gültigen Operator-Rollen.",
      "items": {
        "type": "string",
        "enum": [
          "GENESIS_OPERATOR",
          "RITUAL_OPERATOR",
          "PAYOUT_OPERATOR",
          "ECHO_OPERATOR",
          "SKELETTON_OPERATOR",
          "AUDIT_OPERATOR"
        ]
      }
    }
  },

  "required": ["roles"]
}
