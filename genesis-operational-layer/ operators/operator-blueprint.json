{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CoreCraft Operator Blueprint",
  "description": "Maschinenlesbare Grunddefinition eines Operators innerhalb des Genesis Operational Layer.",
  "type": "object",

  "properties": {
    "operatorId": {
      "type": "string",
      "description": "Deterministisch generierte Identität des Operators."
    },

    "publicKey": {
      "type": "string",
      "description": "Ed25519 Public Key des Operators."
    },

    "role": {
      "type": "string",
      "description": "Funktionale Rolle des Operators.",
      "enum": [
        "GENESIS_OPERATOR",
        "RITUAL_OPERATOR",
        "PAYOUT_OPERATOR",
        "ECHO_OPERATOR",
        "SKELETTON_OPERATOR",
        "AUDIT_OPERATOR"
      ]
    },

    "seal": {
      "type": "string",
      "description": "Signiertes Identitäts-Artefakt des Operators."
    },

    "permissions": {
      "type": "array",
      "description": "Granulare Berechtigungen des Operators.",
      "items": {
        "type": "string",
        "enum": [
          "canTriggerRituals",
          "canWriteEcho",
          "canAuthorizePayouts",
          "canModifyOperators",
          "canModifyGenesis",
          "canModifySkeletton"
        ]
      }
    },

    "active": {
      "type": "boolean",
      "description": "Aktivierungsstatus des Operators."
    }
  },

  "required": [
    "operatorId",
    "publicKey",
    "role",
    "active"
  ]
}
